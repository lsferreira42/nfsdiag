FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Intentionally exposes no rpcbind and no NFS service.
# Expected nfs-doctor result: TCP/111 and TCP/2049 connectivity failures.
CMD ["sleep", "infinity"]
